# Shared container image, normal app runtime profile
HOURNEST_RUNTIME_MODE=app
HOURNEST_PORT=8080

APP_ENV=production
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080
SANCTUM_STATEFUL_DOMAINS=localhost:8080
APP_DEBUG=false
LOG_LEVEL=info

HOURNEST_AUTO_MIGRATE=true
HOURNEST_ENABLE_SCHEDULER=true
HOURNEST_DEMO_REFRESH_ON_BOOT=false

# Authentication
AUTH_OAUTH_ENABLED=false

# Local auth / emergency access
SUPERADMIN_USERNAME=superadmin
# Optional: leave empty to let the container generate an initial password once and print it to the logs.
SUPERADMIN_PASSWORD=

# Database defaults to /var/lib/hournest/database/app.sqlite if left empty.
DB_CONNECTION=sqlite
DB_DATABASE=

# Optional OIDC settings when AUTH_OAUTH_ENABLED=true
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_WELLKNOWN_URL=
OIDC_REDIRECT_URI=

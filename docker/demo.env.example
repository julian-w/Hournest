# Shared container image, demo runtime profile
HOURNEST_RUNTIME_MODE=demo
HOURNEST_PORT=8080

APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080
SANCTUM_STATEFUL_DOMAINS=localhost:8080

APP_DEBUG=false
LOG_LEVEL=info

DEMO_REFERENCE_DATE=now
DEMO_DATASET_VARIANT=standard
DEMO_REFRESH_CRON=*/30 * * * *
DEMO_LOGIN_PASSWORD=public-demo-password
DEMO_NOTICE=Public demo preview. Changes may be reset automatically and some admin actions are disabled.

HOURNEST_AUTO_MIGRATE=true
HOURNEST_ENABLE_SCHEDULER=true
HOURNEST_DEMO_REFRESH_ON_BOOT=true

# Usually left untouched for a public demo
DEMO_ALLOW_PASSWORD_CHANGE=false
DEMO_ALLOW_USER_MANAGEMENT=false
DEMO_ALLOW_GLOBAL_SETTINGS_WRITE=false
DEMO_ALLOW_HOLIDAY_WRITE=false
DEMO_ALLOW_BLACKOUT_WRITE=false

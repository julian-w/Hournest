# ===========================================
# Hournest – Environment Variables
# ===========================================
# Repository-Setup: nach /backend/.env kopieren.
# Release-Paket: als .env im Paket-Root anlegen.
# Danach die Werte ausfüllen.
# ===========================================

# --- App ---
APP_NAME=Hournest
APP_ENV=local
# Leave empty in templates. install.php or the Docker entrypoint can generate this on first boot.
APP_KEY=
APP_DEBUG=true
# Emergency escape hatch only. Prevents startup if the database already contains migrations
# that do not exist in the current code package.
APP_ALLOW_SCHEMA_DOWNGRADE=false
APP_URL=http://localhost:8000

# --- Frontend URL (für CORS & Redirects) ---
FRONTEND_URL=http://localhost:4200

# --- Database ---
DB_CONNECTION=sqlite
DB_DATABASE=/absolute/path/to/backend/database/database.sqlite

# --- Authentication Mode ---
# Set to false for local email/password login (no external SSO needed)
AUTH_OAUTH_ENABLED=true

# --- Container Runtime (Docker entrypoint only) ---
# Use "demo" to start the shared container image in demo mode or "app" for normal operation.
# In Docker, generated secrets are persisted in /var/lib/hournest/env/.env.
HOURNEST_RUNTIME_MODE=app
HOURNEST_AUTO_MIGRATE=true
HOURNEST_ENABLE_SCHEDULER=true
HOURNEST_DEMO_REFRESH_ON_BOOT=true

# --- Demo Mode ---
DEMO_ENABLED=false
# Use "now" for a rolling public demo or a fixed ISO date for deterministic snapshots/tests.
DEMO_REFERENCE_DATE=now
# Use "standard" for broad feature coverage or "full" for a denser showcase dataset.
DEMO_DATASET_VARIANT=standard
# Optional cron expression for automatic refresh via "php artisan schedule:work"
DEMO_REFRESH_CRON=
# Keep this false for real demo deployments. Local/test setups may opt in explicitly.
DEMO_ALLOW_DEFAULT_PASSWORDS=false
# Keep this true so demo refreshes do not hit your normal database by accident.
DEMO_REQUIRE_DEDICATED_DATABASE=true
# This password is intentionally public in demo mode and may be shown on the login page.
DEMO_LOGIN_PASSWORD=demo-password
DEMO_NOTICE=Demo mode is active. Changes may be reset automatically and some admin actions are disabled.
DEMO_ALLOW_PASSWORD_CHANGE=false
DEMO_ALLOW_USER_MANAGEMENT=false
DEMO_ALLOW_GLOBAL_SETTINGS_WRITE=false
DEMO_ALLOW_HOLIDAY_WRITE=false
DEMO_ALLOW_BLACKOUT_WRITE=false
DEMO_ALLOW_WORK_SCHEDULE_WRITE=false
DEMO_ALLOW_VACATION_LEDGER_WRITE=false
DEMO_ALLOW_WORK_TIME_ACCOUNT_WRITE=false
DEMO_ALLOW_COST_CENTER_WRITE=false
DEMO_ALLOW_USER_GROUP_WRITE=false
DEMO_ALLOW_USER_COST_CENTER_WRITE=false
DEMO_ALLOW_TIME_LOCK_WRITE=false
DEMO_ALLOW_VACATION_WRITE=true
DEMO_ALLOW_ABSENCE_WRITE=true
DEMO_ALLOW_TIME_TRACKING_WRITE=true
DEMO_ALLOW_TIME_BOOKING_TEMPLATE_WRITE=true
DEMO_ALLOW_COST_CENTER_FAVORITES_WRITE=true
DEMO_ALLOW_ADMIN_REVIEW_WRITE=true

# --- OpenID Connect (OIDC) ---
# Required when AUTH_OAUTH_ENABLED=true. Works with any OIDC provider.
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_WELLKNOWN_URL=https://your-oidc-provider/.well-known/openid-configuration
OIDC_REDIRECT_URI=${APP_URL}/api/auth/callback

# --- Session / Sanctum ---
SESSION_DRIVER=file
SESSION_LIFETIME=120
SANCTUM_STATEFUL_DOMAINS=localhost:4200

# --- Urlaubseinstellungen ---
DEFAULT_VACATION_DAYS_PER_YEAR=30

# --- Superadmin (Emergency Access) ---
# SUPERADMIN_PASSWORD expects a bcrypt hash, not plaintext.
# Leave it empty here and set it before installation.
# If it is missing, install.php will stop and print a temporary password plus
# a copyable bcrypt hash for your .env file.
# In Docker, the entrypoint can generate an initial password automatically and
# stores only the bcrypt hash in the persistent runtime .env.
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=

# --- Admin Emails (comma-separated, matched on OIDC login) ---
ADMIN_EMAILS=admin@hournest.local

# --- Logging ---
LOG_CHANNEL=stack
LOG_LEVEL=debug
